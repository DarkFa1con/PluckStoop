{
  "name": "pluckstoop",
  "version": "2.0.0",
  "description": "Universal Metadata Scrubber — strip hidden metadata from images, documents, audio and video",
  "main": "main.js",
  "homepage": "https://github.com/muhammadhassnain/pluckstoop",
  "author": {
    "name": "Muhammad Hassnain",
    "email": "mhassnainktk6@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:all": "electron-builder --win --linux --publish never"
  },
  "build": {
    "appId": "com.muhammadhassnain.pluckstoop",
    "productName": "PluckStoop",
    "copyright": "Copyright © 2024 Muhammad Hassnain",
    "icon": "icon.png",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-id3/**",
      "node_modules/jpeg-js/**",
      "node_modules/pngjs/**"
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "splash.html",
      "style.css",
      "icon.png",
      "package.json",
      "node_modules/**"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "ia32"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "icon.png",
      "publisherName": "Muhammad Hassnain",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.png",
      "uninstallerIcon": "icon.png",
      "installerHeaderIcon": "icon.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PluckStoop",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "icon": "icon.png",
      "category": "public.app-category.utilities",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "icon.png",
      "category": "Utility",
      "description": "Universal Metadata Scrubber",
      "maintainer": "Muhammad Hassnain",
      "vendor": "Muhammad Hassnain",
      "synopsis": "Strip hidden metadata from any file"
    },
    "deb": {
      "depends": ["libgtk-3-0", "libnotify4", "libnss3", "libxss1", "libxtst6", "xdg-utils"]
    },
    "directories": {
      "output": "dist",
      "buildResources": "build"
    }
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0",
    "file-type": "^19.0.0",
    "music-metadata": "^10.5.0",
    "pdf-lib": "^1.17.1",
    "node-id3": "^0.2.6",
    "mammoth": "^1.8.0",
    "fast-csv": "^5.0.1",
    "node-stream-zip": "^1.15.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  }
}
